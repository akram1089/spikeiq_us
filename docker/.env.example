# Interactive Brokers Gateway Credentials
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password

# Gateway Configuration Settings
TRADING_MODE=paper
READ_ONLY_API=yes
VNC_SERVER_PASSWORD=vncpass
TZ=America/New_York

# ClickHouse (optional overrides)
CLICKHOUSE_DB=trade_analytics_us
CLICKHOUSE_USER=clickhouse_user
CLICKHOUSE_PASSWORD=change_me_clickhouse_pass

# Comma-separated symbols streamed 24/7 without opening the UI
DEFAULT_STREAM_SYMBOLS=AAPL,MSFT,NVDA,TSLA,SPX,NDX,COMP,SPCX,META,GOOGL,AMZN

# PostgreSQL Security Master
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=trade_analytics
POSTGRES_PASSWORD=change_me_postgres_pass
POSTGRES_DB=security_master
DATABASE_URL=postgresql+psycopg2://trade_analytics:change_me_postgres_pass@127.0.0.1:5432/security_master

# IBKR client IDs (backend and resolve job must differ)
IB_CLIENT_ID=2
IB_RESOLVE_CLIENT_ID=12

# Pre-spike watchlist alerts (optional)
# TELEGRAM_CHAT_ID: numeric id (-100...) for groups, or @YourChannel for public channels
# (bot must be added as channel admin to post).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@SPIKEIQ
PRE_SPIKE_ALERT_POLL_SECONDS=1
PRE_SPIKE_ALERT_LOOKBACK_SECONDS=300

# IBKR contract resolution
IB_RESOLVE_BATCH_SIZE=50
IB_RESOLVE_RETRY_DELAY=2.0
